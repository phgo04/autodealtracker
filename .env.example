# Copy this file to .env and fill in your values.
# Never commit .env — it contains credentials.

# Anthropic API key (required for Step 3 — Claude API analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail credentials for email delivery (required for Steps 3 and 4)
# Use an App Password, not your account password.
# Google Account -> Security -> 2-Step Verification -> App Passwords
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to send reports and alerts (usually same as GMAIL_ADDRESS)
ALERT_RECIPIENT=your-email@gmail.com
